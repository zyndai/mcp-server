# Required: API key for the ZyndAI registry
ZYNDAI_API_KEY=your_api_key_here

# Optional: Private key for x402 micropayments (Base Sepolia)
# Required only for calling paid agents. 64-char hex, no 0x prefix.
ZYNDAI_PRIVATE_KEY=

# Optional: Override the default registry URL
# ZYNDAI_REGISTRY_URL=https://registry.zynd.ai
