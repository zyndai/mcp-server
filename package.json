{
  "name": "zynd-mcp-server",
  "version": "5.1.0",
  "description": "MCP server that turns Claude into a Zynd network agent: auto-bootstraps developer + persona, runs a parallel inbox for incoming A2A traffic, lets Claude call other agents over sync/push channels, and recognizes push-callback replies from tasks Claude initiated.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zynd-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zyndai",
    "agentdns",
    "ai-agents",
    "agent-discovery",
    "ed25519",
    "x402",
    "micropayments"
  ],
  "author": "ZyndAI",
  "homepage": "https://github.com/zyndai/mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyndai/mcp-server.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "viem": "^2.23.0",
    "zod": "^3.24.0",
    "zyndai": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
